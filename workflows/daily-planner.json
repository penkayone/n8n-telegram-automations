      "id": "ghlist",
      "name": "GitHub: список карточек",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        304
      ],
      "retryOnFail": true,
      "waitBetweenTries": 3000,
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_GITHUB_CREDENTIAL_ID",
          "name": "GitHub read"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const incoming = $input.all();\nlet files;\nif (incoming.length === 1 && Array.isArray(incoming[0].json)) {\n  files = incoming[0].json;\n} else if (incoming.length === 1 && incoming[0].json && Array.isArray(incoming[0].json.body)) {\n  files = incoming[0].json.body;\n} else {\n  files = incoming.map(i => i.json);\n}\nreturn files\n  .filter(f => f && f.type === 'file' && typeof f.name === 'string' && f.name.endsWith('.md'))\n  .map(f => ({ json: { path: f.path, name: f.name } }));"
      },
      "id": "expand",
      "name": "Развернуть список .md",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        304
      ]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/YOUR_GITHUB_USER/YOUR_VAULT_REPO/contents/{{ $json.path }}?ref=main",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
