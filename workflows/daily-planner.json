      "id": "ghcard",
      "name": "GitHub: карточка",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        880,
        304
      ],
      "retryOnFail": true,
      "waitBetweenTries": 3000,
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_GITHUB_CREDENTIAL_ID",
          "name": "GitHub read"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const mapNode = $('GitHub: MAP').first().json;\nconst decode = (c) => Buffer.from(String(c || '').replace(/\\n/g, ''), 'base64').toString('utf8');\nconst mapText = mapNode.content ? decode(mapNode.content) : (mapNode.data || '');\n\nconst cards = $input.all().map(i => {\n  const j = i.json;\n  const text = j.content ? decode(j.content) : (j.data || '');\n  return `### ${j.name || j.path || 'card'}\\n${text}`;\n}).join('\\n\\n');\n\nconst today = $now.toFormat('dd.MM');\n\nconst combined = `Сегодня: ${today}\\n\\n# MAP.md\\n${mapText}\\n\\n# Карточки проектов\\n${cards}`;\n\nconst system = [\n  'Ты ассистент Антона. Сформируй утренний дайджест строго по структуре ниже, без отклонений.',\n  'Стиль: русский, без длинного тире (вместо него запятая), без буквы е с точками (обычная е), кратко, с цифрами, честно.',\n  'Форматирование для Telegram parse_mode HTML: жирность только тегами <b></b>. В обычном тексте не используй символы < > &.',\n  'Дата для заголовка передана в начале сообщения пользователя как Сегодня, подставь ее, не выдумывай день.',\n  '',\n  'Структура вывода (соблюдай эмодзи, теги и порядок):',\n  '☀️ <b>План на [дата ДД.ММ]</b>',\n  '🎯 <b>Фокус дня</b>',\n  'Одна строка, главное на сегодня.',\n  '<b>Приоритеты</b>',\n  'Для каждой задачи (3-5, по важности):',\n  'N. <b>Заголовок</b> (проект)',\n  '• что сделать',\n  '• критерий готовности или следующий шаг',\n  '⚠️ <b>Риски и блокеры</b>',\n  '• что заблокировано, просрочено или требует решения',\n  '🧊 <b>Не трогать / заморожено</b>',\n  '• пункты с явным правилом не начинать',\n  '',\n  'Если по разделу нет данных, пропусти весь раздел. Уложись в 3500 символов.'\n].join('\\n');\n\nreturn [{\n  json: {\n    body: {\n      model: 'claude-sonnet-4-6',\n      max_tokens: 2000,\n      system: system,\n      messages: [\n        { role: 'user', content: combined }\n      ]\n    }\n  }\n}];"
      },
